0:["hNUN2dE3TWj6Xu6QkYQ60",[[["",{"children":["about",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["about",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"mx-auto max-w-4xl px-6 py-12 space-y-10","children":[["$","div",null,{"children":[["$","h1",null,{"className":"section-title","children":"The gap between observation and action is where learning is lost."}],["$","p",null,{"className":"mt-4 text-base text-black/70","children":"Every day, teachers deliver instruction across multiple tasks and activities. But without a structured way to capture what students actually understand—in real time, across each component of the lesson—critical signals get lost. The student who nailed the warm‑up but fell apart during guided practice. The group that sailed through computation but couldn't apply it in context. These patterns matter, and they disappear by the end of the period."}],["$","p",null,{"className":"mt-4 text-base font-semibold text-black/90","children":"Academic Monitoring was built to close that gap."}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"What Academic Monitoring Does"}],["$","p",null,{"className":"text-base text-black/70","children":"Academic Monitoring is a streamlined digital tool that allows teachers to observe and record student performance across three distinct learning tasks each day. By breaking the lesson into its component parts—and capturing quick performance indicators during each—teachers generate a continuous, granular picture of how every student is progressing."}],["$","p",null,{"className":"text-base text-black/70","children":"The result is actionable data that supports the instructional decisions districts are already asking teachers to make: forming flexible small groups based on demonstrated skill gaps, adjusting pacing within a unit, identifying students who need Tier 2 or Tier 3 intervention, and documenting evidence for MTSS teams and parent conferences."}],["$","p",null,{"className":"text-base font-medium text-black/80","children":"One tap per student. Three tasks per day. A complete picture of learning over time."}]]}],["$","div",null,{"className":"space-y-6","children":[["$","div",null,{"className":"text-xl font-semibold","children":"Grounded in Research"}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"Formative Assessment"}],["$","p",null,{"className":"text-base text-black/70","children":"In their landmark 1998 review of more than 250 studies, Black and Wiliam found that strengthening the frequency and quality of classroom‑level feedback produced achievement gains between 0.4 and 0.7 standard deviations—among the largest effects reported in educational research. Their central finding was clear: when teachers collect evidence of student understanding as learning happens and use it to adjust instruction, students learn more. The challenge has always been making this process practical enough to sustain daily. Academic Monitoring was designed to solve that problem."}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"Visible Learning & Teacher Clarity"}],["$","p",null,{"className":"text-base text-black/70","children":"John Hattie's synthesis of over 1,200 meta‑analyses across millions of students established that the most powerful classroom practices share a common thread: teachers who monitor student progress in real time and adjust instruction based on what they see. In Hattie's framework, feedback carries an effect size of 0.70, formative evaluation registers at 0.48, and teacher clarity—knowing what students should learn, where they are, and what comes next—is among the strongest predictors of achievement. Academic Monitoring gives teachers a lightweight structure to practice all three simultaneously."}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"Multi‑Tiered Systems of Support (MTSS)"}],["$","p",null,{"className":"text-base text-black/70","children":"Effective MTSS implementation depends on reliable, timely data at every tier. Universal screening identifies which students may be at risk. Progress monitoring determines whether interventions are working. But between those formal checkpoints, the daily classroom is where most instructional decisions are actually made. Academic Monitoring fills this space by generating the kind of frequent, skill‑specific data that MTSS teams need to form targeted small groups, adjust intervention intensity, and document student response—all without adding another assessment to the calendar."}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"Classroom Monitoring & Student Accountability"}],["$","p",null,{"className":"text-base text-black/70","children":"Research compiled by the Northwest Regional Educational Laboratory found a consistent relationship across dozens of studies: when teachers actively monitor student work against clear standards—through circulation, questioning, and structured observation—student effort and achievement increase. The studies further found that the frequency and regularity of monitoring matter as much as the monitoring itself. Academic Monitoring builds this habit into the daily workflow by giving teachers a repeatable, low‑friction structure for capturing evidence during every instructional block."}]]}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"Designed for How Teachers Actually Work"}],["$","p",null,{"className":"text-base text-black/70","children":"Academic Monitoring was designed by a classroom teacher, tested with students, and built for the realities of daily instruction. There are no lengthy rubrics to complete, no forms to fill out after school, and no separate assessment platform to learn. Teachers tap through performance levels as they circulate—the same instructional laps they're already taking."}],["$","p",null,{"className":"text-base text-black/70","children":"The tool then organizes that data into clear, exportable reports that support weekly planning meetings, PLC discussions, parent communication, MTSS documentation, and administrator walkthroughs."}]]}],["$","div",null,{"className":"space-y-6","children":[["$","div",null,{"className":"text-xl font-semibold","children":"Why District Leaders Choose Academic Monitoring"}],["$","div",null,{"className":"hero-card p-6 space-y-5","children":[["$","div",null,{"children":[["$","div",null,{"className":"text-lg font-semibold","children":"Consistency across classrooms"}],["$","p",null,{"className":"text-base text-black/70","children":"When every teacher in a building uses the same observation framework, leadership teams gain visibility into instructional trends across grade levels, content areas, and schools—without adding testing days."}]]}],["$","div",null,{"children":[["$","div",null,{"className":"text-lg font-semibold","children":"Alignment with existing initiatives"}],["$","p",null,{"className":"text-base text-black/70","children":"Academic Monitoring supports and strengthens the formative assessment practices, MTSS frameworks, and data‑driven instruction models that districts have already invested in. It does not replace those systems. It makes them work better by ensuring teachers have the daily data those systems require."}]]}],["$","div",null,{"children":[["$","div",null,{"className":"text-lg font-semibold","children":"Reduced teacher burden"}],["$","p",null,{"className":"text-base text-black/70","children":"The most common barrier to sustained formative practice is time. Academic Monitoring compresses observation, recording, and reporting into a single workflow so teachers spend less time documenting and more time teaching."}]]}],["$","div",null,{"children":[["$","div",null,{"className":"text-lg font-semibold","children":"Evidence that travels"}],["$","p",null,{"className":"text-base text-black/70","children":"Student performance data captured in Academic Monitoring can follow a student from classroom to intervention team to parent conference to the next grade level—creating continuity that spreadsheets and sticky notes cannot provide."}]]}]]}]]}],["$","div",null,{"className":"hero-card p-6 space-y-4","children":[["$","div",null,{"className":"text-lg font-semibold","children":"The Bottom Line"}],["$","p",null,{"className":"text-base text-black/70","children":"The research is clear: frequent monitoring of student learning, combined with responsive instructional adjustments, is one of the most effective levers available to schools. The barrier has never been whether teachers should do it. The barrier has been making it sustainable."}],["$","p",null,{"className":"text-base font-semibold text-black/90","children":"Academic Monitoring removes that barrier."}]]}],["$","p",null,{"className":"text-sm text-black/50 italic text-center","children":"Academic Monitoring was created by a practicing educator committed to respecting teachers' time and improving student outcomes."}]]}],null],null],null]},[null,["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","about","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined"}]],null]},[[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/42e29054fb0b3408.css","precedence":"next","crossOrigin":"$undefined"}]],["$","html",null,{"lang":"en","children":["$","body",null,{"children":["$","div",null,{"className":"app-shell","children":[["$","$L4",null,{}],["$","main",null,{"className":"flex-1","children":["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","justifyContent":"center"},"children":["$","div",null,{"children":[["$","style",null,{"dangerouslySetInnerHTML":{"__html":"body{color:#000;background:#fff;margin:0}.next-error-h1{border-right:1px solid rgba(0,0,0,.3)}@media (prefers-color-scheme:dark){body{color:#fff;background:#000}.next-error-h1{border-right:1px solid rgba(255,255,255,.3)}}"}}],["$","h1",null,{"className":"next-error-h1","style":{"display":"inline-block","margin":"0 20px 0 0","padding":"0 23px 0 0","fontSize":24,"fontWeight":500,"verticalAlign":"top","lineHeight":"49px"},"children":"404"}],["$","div",null,{"style":{"display":"inline-block"},"children":["$","h2",null,{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]],"notFoundStyles":[]}]}]]}]}]}]],null],null],["$L5",null]]]]
